# Julia tracking and environment overrides
Manifest.toml
.julia/
dev/

# Local data cache and links (Never commit raw NetCDF or massive CSVs)
data/ncar_eol_dee0099881/*.nc
data/ncar_eol_dee0099881/*.csv
data/gabs3/**/*.nc
data/gabs3/**/*.csv
data/drafts/trajectories/*.csv
data/drafts/diagnostics_curated.csv
data/outputs/*.csv
data/outputs/*.json
drafts/sections/generated/*.tex

# Report compilation artifacts and caches
reports/cases99_run/generated/*.tex
reports/cases99_run/tikz-cache/**
reports/cases99_run/*.pdf
reports/cases99_run/*.aux
reports/cases99_run/*.fls
reports/cases99_run/*.fdb_latexmk

# System and OS clutter
.DS_Store
Thumbs.db

# TeX logs and engine outputs generated during report compilation
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.pdf
!data/drafts/figures/*.pdf  # Keep explicit manuscript figures if tracked manually