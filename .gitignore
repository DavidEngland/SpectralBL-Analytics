# OS and editor noise
.DS_Store
Thumbs.db

# Track curated VS Code workspace config files.
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json

# Julia local environment/cache
.julia/
.julia/logs/
dev/

# Build and runtime logs
*.log

# TeX intermediate artifacts
*.aux
*.fdb_latexmk
*.fls
*.out
*.toc
*.synctex.gz

# Manuscript compilation artifacts
manuscript/*.aux
manuscript/*.log
manuscript/*.out
manuscript/*.toc
manuscript/*.bbl
manuscript/*.blg
manuscript/*.fdb_latexmk
manuscript/*.fls
manuscript/*.synctex.gz
manuscript/sections/*.aux

# Report run artifacts (generated, reproducible)
reports/cases99_run/generated/*.tex
reports/cases99_run/tikz-cache/**
reports/cases99_run/main.pdf
reports/cases99_run/main.aux
reports/cases99_run/main.fls
reports/cases99_run/main.fdb_latexmk
reports/cases99_run/main.log
reports/cases99_run/main.out
reports/cases99_run/main.toc

# Data protection: ignore all dataset payloads by default
data/**

# Keep directory scaffolding in git
!data/**/
!data/**/.gitkeep