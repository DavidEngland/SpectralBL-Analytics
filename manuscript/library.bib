@techReport{,
   abstract = {It is currently not well understood how the planetary boundary layer (PBL) dynamics affects 14 the formation and growth of ultrafine particles in the atmosphere, because of the limited co-located 15 aerosol size distributions and lidar measurements. Here we show, from long-term in-situ observations, a 16 clear link between boundary layer processes and surface aerosol dynamics. Aerosol size distributions in 17 the diameter range from 7-300 nm were measured with a scanning mobility particle sizer (SMPS) at the 18 University of Alabama Huntsville campus in 2016, 2017, and 2022. The backscatter of larger aerosols 19 was measured using a co-located lidar ceilometer. Meteorological surface parameters including 20 temperature, relative humidity, station pressure, wind speed and direction, solar radiation, and 21 precipitation were also measured. New particle formation (NPF) and long growth (over 12 hours) events 22 occurred most frequently during the winter, unlike many other locations where NPF events occur more 23 frequently in spring and fall, indicating that cooler temperatures play important roles in ultrafine particle 24 formation in the warm subtropical environment. During the summer with strong solar radiation, there 25 were more short-time growth events (less than 6 hours), likely associated with convection within the 26 boundary layer. Our observations also show cold fronts affect the measured aerosol size distributions 27 because the combination of precipitation scavenging and cleaner air can provide thermodynamic 28 conditions favorable for NPF and aerosol growth. These results highlight the importance of meteorology 29 on aerosol formation and growth. 30 31},
   author = {Zachary Watson and Lee Tiszenkel and Arastoo Pour Biazar and Kevin Knupp and Shan-Hu Lee},
   keywords = {32 Ultrafine particles,atmospheric dynamics,boundary layer,meteorology,new particle formation},
   title = {Effects of Boundary Layer Dynamics and Meteorology on Ultrafine Particle Formation and 1 Growth 2 3}
}
